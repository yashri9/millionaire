# ============================================================================
# Deck Agent (web/) — environment variables
# Copy to ".env.local" and fill in. NEVER commit .env.local.
#
# SECURITY: Only NEXT_PUBLIC_* vars are shipped to the browser. Every secret
# below (service role key, LLM keys, email keys) is SERVER-ONLY and must never
# be referenced from client components. This is the exact bug class hit earlier
# (an LLM key in browser JS) — do not repeat it.
# ============================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (browser-safe) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Supabase (SERVER ONLY — bypasses RLS; used for recipient/service paths) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: direct Postgres connection for CLI migrations (quote if password has special chars)
# DATABASE_URL="postgresql://postgres:YOUR-PASSWORD@db.dtnvnsxdbsgjjpfsyoxn.supabase.co:5432/postgres"

# Storage bucket for uploaded decks
SUPABASE_DECKS_BUCKET=decks

# ---- LLM provider (SERVER ONLY) — pluggable, mirrors backend/llm.py ----
# LLM_PROVIDER: "groq" (default) or "anthropic"
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Optional (only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01

# ---- Google OAuth (configured in Supabase Auth dashboard; these are for reference) ----
# Set the Client ID/Secret inside Supabase Auth > Providers > Google.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Email provider (SERVER ONLY) — verification / reset / escalation ----
# EMAIL_PROVIDER: "resend" | "postmark" | "dev" (dev = log to console, no send)
EMAIL_PROVIDER=dev
EMAIL_FROM=Deck Agent <notify@yourdomain.com>
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=

# ---- Recipient Q&A rate limiting (PRD §11.6) ----
ASK_RATE_LIMIT_PER_SESSION=20
