# Copy this file to ".env" and fill in your key.
# The backend loads it on startup (python-dotenv).

# Which model provider to use: "groq" or "anthropic".
# Switching providers is JUST this one line — no code changes.
LLM_PROVIDER=groq

# --- Groq (OpenAI-compatible) -------------------------------------
# Get a key at https://console.groq.com/keys  (keys start with gsk_)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Anthropic ----------------------------------------------------
# Get a key at https://console.anthropic.com/  (keys start with sk-ant-)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01

# --- Deck conversion ----------------------------------------------
# Optional: absolute path to the LibreOffice "soffice" binary.
# Only needed for .ppt / .pptx page rendering if it is not on your PATH
# or in a standard install location.
# Windows example:
# SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
SOFFICE_PATH=
